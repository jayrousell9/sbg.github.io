    <div style="max-width:480px; margin:3rem auto; background:var(--green-card); border:1px solid var(--divider); padding:2rem var(--side);">

      <!-- Not confirmed state -->
      <div id="selfserve-form-state">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
          <h2 style="font-size:1.35rem; font-weight:800; color:var(--cream); letter-spacing:-0.02em;">Set up self-serve</h2>
          <button onclick="closeSelfServe()" style="background:none; border:none; color:var(--label); font-size:1.5rem; cursor:pointer; line-height:1;">✕</button>
        </div>
        <p style="color:var(--muted); font-size:0.875rem; margin-bottom:2rem;">Create your account to access your policy, download your pink card, and manage your coverage anytime.</p>

        <div class="field-group">
          <label>Full name</label>
          <input type="text" placeholder="Jane Smith" />
        </div>
        <div class="field-group">
          <label>Email address</label>
          <input type="email" placeholder="jane@email.com" />
        </div>
        <div class="field-group">
          <label>Policy number</label>
          <input type="text" placeholder="e.g. POL-2026-00123" />
        </div>
        <div class="field-group">
          <label>Create a password</label>
          <input type="password" placeholder="Minimum 8 characters" />
        </div>
        <div class="field-group">
          <label>Confirm password</label>
          <input type="password" placeholder="Repeat password" />
        </div>

        <button class="btn-next" style="width:100%; margin-top:0.5rem;" onclick="confirmSelfServe()">Create my account →</button>
        <button onclick="closeSelfServe()" style="width:100%; margin-top:0.75rem; background:none; border:none; color:var(--label); font-family:var(--font); font-size:0.78rem; font-weight:600; letter-spacing:0.06em; text-transform:uppercase; cursor:pointer;">Cancel</button>
      </div>

      <!-- Confirmed state -->
      <div id="selfserve-confirm-state" style="display:none; text-align:center; padding:2rem 0;">
        <div style="font-size:3rem; margin-bottom:1rem;">✅</div>
        <h2 style="font-size:1.35rem; font-weight:800; color:var(--cream); margin-bottom:0.75rem;">You're all set!</h2>
        <p style="color:var(--muted); font-size:0.9rem; margin-bottom:2rem;">Your self-serve account has been created. Check your email for a confirmation link.</p>
        <button class="btn-next" onclick="closeSelfServe()">Close →</button>
      </div>

    </div>
  </div><!-- /selfserve-overlay -->

  <!-- ── Footer ─────────────────────────────────────────── -->
  <footer>
    <p>© 2026 Insurance <span class="amp">&</span> Shoebox · This is a demo site · Not a licensed insurer</p>
  </footer>


  <!-- ── Scripts ────────────────────────────────────────── -->
  <script>
    let selectedPlan = 'Standard — $124/mo';

    // ── Page routing ─────────────────────────────────────
    function showPage(name) {
      document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
      document.getElementById('page-' + name).classList.add('active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function goHome() {
      showPage('landing');
      setNav('home');
      trackEvent('page_view', { page_title: 'landing' });
    }

    function setNav(key) {
      document.querySelectorAll('.nav-links button').forEach(b => b.classList.remove('active'));
      const btn = document.getElementById('nav-' + key);
      if (btn) btn.classList.add('active');
    }

