      6: {
        tag: 'Auto Insurance',
        title: 'Quis nostrud: winter tires and your insurance rate — what\'s the connection?',
        meta: '3 min read · Auto Insurance · March 2026',
        body: `<p style="margin-bottom:1.25rem;">Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium, totam rem aperiam eaque ipsa quae ab illo inventore veritatis.</p><p style="margin-bottom:1.25rem;">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam quis nostrud exercitation.</p><p>Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum sed ut perspiciatis unde omnis iste natus.</p>`
      }
    };

    function showArticle(id) {
      const a = articles[id];
      if (!a) return;
      document.getElementById('article-tag').textContent = a.tag;
      document.getElementById('article-title').textContent = a.title;
      document.getElementById('article-meta').textContent = a.meta;
      document.getElementById('article-body').innerHTML = a.body;
      showPage('article');
      trackEvent('article_view', { article_id: id, article_title: a.title });
    }

    // ── Self-serve modal ──────────────────────────────────
    function openSelfServe() {
      document.getElementById('selfserve-overlay').style.display = 'block';
      document.getElementById('selfserve-form-state').style.display = 'block';
      document.getElementById('selfserve-confirm-state').style.display = 'none';
      document.body.style.overflow = 'hidden';
      trackEvent('selfserve_open');
    }
    function closeSelfServe() {
      document.getElementById('selfserve-overlay').style.display = 'none';
      document.body.style.overflow = '';
    }
    function confirmSelfServe() {
      document.getElementById('selfserve-form-state').style.display = 'none';
      document.getElementById('selfserve-confirm-state').style.display = 'block';
      trackEvent('selfserve_signup_complete');
    }
    // Close modal on overlay click
    document.getElementById('selfserve-overlay').addEventListener('click', function(e) {
      if (e.target === this) closeSelfServe();
    });

    // ── Quote flow ────────────────────────────────────────
    function startQuote() {
      showPage('quote');
      showStep(1);
      trackEvent('quote_start', { funnel_step: 'start' });
    }

    function showStep(n) {
      for (let i = 1; i <= 4; i++) {
        const el = document.getElementById('step-' + i);
        if (el) el.style.display = (i === n) ? 'block' : 'none';
      }
      updateProgress(n);
    }

    function goStep(n) {
      const stepNames = {
        1: 'about_you',
        2: 'driving_details',
        3: 'your_quote',
        4: 'payment'
      };
      showStep(n);
      trackEvent('funnel_step_' + n, {
        funnel_step: stepNames[n] || n,
        step_number: n
      });
    }

    function selectPlan(name, price) {
      selectedPlan = name + ' — ' + price;
      trackEvent('plan_selected', { plan_name: name, plan_price: price });
      goStep(4);
    }

    function confirmPurchase() {
      const agreed = document.getElementById('agree').checked;
      if (!agreed) {
        alert('Please agree to the terms and conditions to continue.');
        return;
      }
      document.getElementById('confirm-plan').textContent = selectedPlan;
      const today = new Date().toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
      document.getElementById('confirm-date').textContent = today;
      trackEvent('purchase_complete', { funnel_step: 'confirmation', plan: selectedPlan });
      showPage('confirm');
    }

    // ── Progress bar ──────────────────────────────────────
    function updateProgress(activeStep) {
      for (let i = 1; i <= 5; i++) {
        const el = document.getElementById('prog-' + i);
        if (!el) continue;
        el.classList.remove('active', 'done');
        if (i < activeStep)  el.classList.add('done');
        if (i === activeStep) el.classList.add('active');
      }
    }

    // ── Address suggestions ───────────────────────────────
    function handleAddress(val) {
      const box = document.getElementById('address-suggestions');
      box.classList.toggle('open', val.length > 2);
    }
    function selectAddress(addr) {
      document.getElementById('address').value = addr;
      document.getElementById('address-suggestions').classList.remove('open');
    }
    document.addEventListener('click', function(e) {
      if (!e.target.closest('.address-wrap')) {
        document.getElementById('address-suggestions').classList.remove('open');
      }
    });
  </script>

</body>
