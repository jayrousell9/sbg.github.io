  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700;800&display=swap" rel="stylesheet" />

  <style>
    /* ── Tokens ───────────────────────────────────────────── */
    :root {
      --green:       #464F56;
      --green-deep:  #2E3539;
      --green-card:  #3A4248;
      --green-hover: #3F474E;
      --cream:       #EDE9E1;
      --muted:       #D4CEBF;
      --label:       #C2D0D6;
      --divider:     #5A6370;
      --pink:        #B5437A;
      --hero-block:  #2E3539;
      --font: 'Open Sans', system-ui, sans-serif;
      --max-w: 680px;
      --side: clamp(1.25rem, 5vw, 2rem);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--green);
      color: var(--cream);
      font-family: var(--font);
      font-size: 1rem;
      line-height: 1.75;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }

    /* ── Pages ────────────────────────────────────────────── */
    .page { display: none; }
    .page.active { display: block; }

    /* ── Nav ──────────────────────────────────────────────── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--green-deep);
      padding: 0 var(--side);
      border-bottom: 1px solid var(--divider);
    }
    .nav-inner {
      max-width: calc(var(--max-w) + 4rem);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
      gap: 1rem;
    }
    .nav-logo {
      font-size: 1rem;
      font-weight: 800;
      color: var(--cream);
      cursor: pointer;
      flex-shrink: 0;
      letter-spacing: -0.01em;
    }
    .nav-logo .amp { color: var(--pink); }
    .nav-links {
      display: flex;
      gap: clamp(0.75rem, 3vw, 1.75rem);
      list-style: none;
    }
    .nav-links button {
      background: none;
      border: none;
      border-bottom: 2px solid transparent;
      font-family: var(--font);
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--label);
      cursor: pointer;
      padding: 0.25rem 0;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      transition: color 0.2s;
      white-space: nowrap;
    }
    .nav-links button:hover  { color: var(--cream); }
    .nav-links button.active { color: var(--cream); border-bottom-color: var(--cream); }
    .nav-links button.login-btn {
      background: var(--cream);
      color: var(--green);
      padding: 0.35rem 1rem;
      font-weight: 700;
    }
    .nav-links button.login-btn:hover { background: var(--muted); color: var(--green-deep); }

    /* ── Layout ───────────────────────────────────────────── */
    .container {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 var(--side);
    }

    /* ── Hero ─────────────────────────────────────────────── */
    .hero-block {
      background: var(--hero-block);
      border-bottom: 4px solid var(--pink);
      padding: clamp(4rem, 12vw, 8rem) var(--side);
      text-align: center;
    }
    .hero-block .eyebrow {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--pink);
      margin-bottom: 1rem;
    }
    .hero-block h1 {
      font-size: clamp(2rem, 6vw, 3.5rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--cream);
      margin-bottom: 1.25rem;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }
    .hero-block p {
      font-size: 1.05rem;
      color: var(--muted);
      font-weight: 300;
      max-width: 480px;
      margin: 0 auto 2.5rem;
    }
    .btn-primary {
      display: inline-block;
      background: var(--pink);
      color: #fff;
      font-family: var(--font);
      font-size: 0.9rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      padding: 1rem 2.5rem;
      border: none;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s;
      text-transform: uppercase;
    }
    .btn-primary:hover { background: #922E62; transform: translateY(-2px); }

    /* ── Trust bar ────────────────────────────────────────── */
    .trust-bar {
      background: var(--green-card);
      border-bottom: 1px solid var(--divider);
      padding: 1.25rem var(--side);
      text-align: center;
    }
    .trust-bar p {
      font-size: 0.78rem;
      color: var(--label);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-weight: 600;
    }

    /* ── Content sections ─────────────────────────────────── */
    .content-section {
      padding: 3.5rem var(--side);
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .section-title {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--label);
      margin-bottom: 0.5rem;
    }
    .content-section h2 {
      font-size: clamp(1.4rem, 4vw, 2rem);
      font-weight: 800;
      color: var(--cream);
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
    }
    .content-section p {
      color: var(--muted);
      font-size: 0.95rem;
      margin-bottom: 1rem;
    }

    /* ── Feature cards ────────────────────────────────────── */
    .feature-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1px;
      background: var(--divider);
      border: 1px solid var(--divider);
      margin-top: 2rem;
    }
    .feature-card {
      background: var(--green-card);
      padding: 1.5rem;
    }
    .feature-card .icon { font-size: 1.5rem; margin-bottom: 0.75rem; }
    .feature-card h3 { font-size: 0.95rem; font-weight: 700; color: var(--cream); margin-bottom: 0.35rem; }
    .feature-card p  { font-size: 0.82rem; color: var(--muted); }

    /* ── Quote form wrapper ───────────────────────────────── */
    .quote-wrap {
      min-height: calc(100vh - 64px);
      padding: 3rem var(--side) 5rem;
    }

    /* ── Progress bar ─────────────────────────────────────── */
    .progress-bar {
      max-width: var(--max-w);
      margin: 0 auto 2.5rem;
    }
    .progress-steps {
      display: flex;
      align-items: center;
      gap: 0;
    }
    .prog-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      flex: 1;
      position: relative;
    }
    .prog-step:not(:last-child)::after {
      content: '';
      position: absolute;
      top: 14px;
      left: 50%;
      width: 100%;
      height: 2px;
      background: var(--divider);
      z-index: 0;
    }
    .prog-step.done:not(:last-child)::after  { background: var(--cream); }
    .prog-dot {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: var(--divider);
      color: var(--green);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.72rem;
      font-weight: 700;
      position: relative;
      z-index: 1;
      transition: background 0.2s;
    }
    .prog-step.active .prog-dot { background: var(--cream); color: var(--green-deep); }
    .prog-step.done .prog-dot   { background: var(--pink);  color: #fff; }
    .prog-label {
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--label);
      margin-top: 0.4rem;
      text-align: center;
      white-space: nowrap;
    }
    .prog-step.active .prog-label { color: var(--cream); }

    /* ── Form card ────────────────────────────────────────── */
    .form-card {
      max-width: var(--max-w);
      margin: 0 auto;
      background: var(--green-card);
      border: 1px solid var(--divider);
      padding: clamp(1.5rem, 5vw, 2.5rem);
    }
    .form-card h2 {
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--cream);
      letter-spacing: -0.02em;
      margin-bottom: 0.35rem;
    }
    .form-card .form-subtitle {
      font-size: 0.875rem;
      color: var(--muted);
      margin-bottom: 2rem;
    }

    /* ── Form fields ──────────────────────────────────────── */
    .field-group { margin-bottom: 1.25rem; }
    .field-group label {
      display: block;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--label);
      margin-bottom: 0.4rem;
    }
    .field-group input,
    .field-group select {
      width: 100%;
      background: var(--green);
      border: 1px solid var(--divider);
      color: var(--cream);
      font-family: var(--font);
      font-size: 0.95rem;
      padding: 0.75rem 1rem;
      outline: none;
      transition: border-color 0.2s;
      -webkit-appearance: none;
    }
    .field-group input::placeholder { color: var(--label); opacity: 0.6; }
    .field-group input:focus,
    .field-group select:focus { border-color: var(--cream); }
    .field-group select option { background: var(--green-deep); }

    .field-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    @media (max-width: 480px) { .field-row { grid-template-columns: 1fr; } }

    /* Address suggestions */
    .address-wrap { position: relative; }
    .address-suggestions {
      position: absolute;
      top: 100%;
      left: 0; right: 0;
      background: var(--green-deep);
      border: 1px solid var(--divider);
      border-top: none;
      z-index: 10;
      display: none;
    }
    .address-suggestions.open { display: block; }
    .suggestion-item {
      padding: 0.65rem 1rem;
      font-size: 0.875rem;
      color: var(--muted);
      cursor: pointer;
      transition: background 0.15s;
    }
    .suggestion-item:hover { background: var(--green-card); color: var(--cream); }

    /* ── Form nav buttons ─────────────────────────────────── */
    .form-actions {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 2rem;
      gap: 1rem;
    }
    .btn-back {
      background: none;
      border: 1px solid var(--divider);
      color: var(--muted);
      font-family: var(--font);
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.7rem 1.25rem;
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s;
    }
    .btn-back:hover { border-color: var(--cream); color: var(--cream); }
    .btn-next {
      background: var(--cream);
      color: var(--green-deep);
      font-family: var(--font);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.8rem 2rem;
      border: none;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s;
    }
    .btn-next:hover { background: var(--muted); transform: translateY(-1px); }

    /* ── Quote options ────────────────────────────────────── */
    .quote-options {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--divider);
      border: 1px solid var(--divider);
      margin: 1.5rem 0;
    }
    @media (max-width: 560px) {
      .quote-options { grid-template-columns: 1fr; }
    }
    .quote-option {
      background: var(--green-card);
      padding: 1.5rem 1.25rem;
      text-align: center;
      position: relative;
    }
    .quote-option.recommended {
      background: var(--green-deep);
      border: 2px solid var(--cream);
    }
    .recommended-badge {
      position: absolute;
      top: -1px; left: 50%;
      transform: translateX(-50%);
      background: var(--cream);
      color: var(--green-deep);
      font-size: 0.6rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.2rem 0.75rem;
    }
    .quote-option h3 {
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--label);
      margin-bottom: 0.75rem;
    }
    .quote-option.recommended h3 { color: var(--muted); }
    .quote-price {
      font-size: 2rem;
      font-weight: 800;
      color: var(--cream);
      letter-spacing: -0.03em;
      line-height: 1;
      margin-bottom: 0.25rem;
    }
    .quote-period {
      font-size: 0.72rem;
      color: var(--label);
      margin-bottom: 1rem;
    }
    .quote-features {
      list-style: none;
      margin-bottom: 1.5rem;
      text-align: left;
    }
    .quote-features li {
      font-size: 0.78rem;
      color: var(--muted);
      padding: 0.3rem 0;
      border-bottom: 1px solid var(--divider);
    }
    .quote-features li::before { content: '✓  '; color: var(--cream); font-weight: 700; }
    .btn-bind {
      width: 100%;
      background: var(--green);
      color: var(--cream);
      font-family: var(--font);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      padding: 0.75rem;
      border: 1px solid var(--divider);
      cursor: pointer;
      transition: background 0.2s;
    }
    .quote-option.recommended .btn-bind {
      background: var(--cream);
      color: var(--green-deep);
      border-color: var(--cream);
    }
    .btn-bind:hover { background: var(--muted); color: var(--green-deep); }

    /* ── Payment ──────────────────────────────────────────── */
    .disclosure-box {
      background: var(--green);
      border: 1px solid var(--divider);
      padding: 1rem;
      margin: 1.25rem 0;
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.6;
      max-height: 120px;
      overflow-y: auto;
    }
    .checkbox-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-top: 1rem;
    }
    .checkbox-row input[type="checkbox"] {
      width: 18px; height: 18px;
      accent-color: var(--cream);
      cursor: pointer;
      flex-shrink: 0;
    }
    .checkbox-row label {
      font-size: 0.85rem;
      color: var(--cream);
      cursor: pointer;
      font-weight: 600;
    }

    /* ── Confirmation ─────────────────────────────────────── */
    .confirm-wrap {
      max-width: var(--max-w);
      margin: 0 auto;
      text-align: center;
      padding: 4rem var(--side);
    }
    .confirm-icon {
      font-size: 3.5rem;
      margin-bottom: 1.25rem;
    }
    .confirm-wrap h1 {
      font-size: clamp(1.75rem, 5vw, 2.75rem);
      font-weight: 800;
      color: var(--cream);
      letter-spacing: -0.02em;
      margin-bottom: 0.75rem;
    }
    .confirm-wrap p {
      color: var(--muted);
      font-size: 0.95rem;
      max-width: 440px;
      margin: 0 auto 2rem;
    }
    .coverage-summary {
      background: var(--green-card);
      border: 1px solid var(--divider);
      padding: 1.5rem;
      text-align: left;
      margin: 2rem auto;
      max-width: 480px;
    }
    .coverage-summary h3 {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--label);
      margin-bottom: 1rem;
    }
    .coverage-row {
      display: flex;
      justify-content: space-between;
      padding: 0.6rem 0;
      border-bottom: 1px solid var(--divider);
      font-size: 0.875rem;
    }
    .coverage-row:last-child { border-bottom: none; }
    .coverage-row span:first-child { color: var(--muted); }
    .coverage-row span:last-child  { color: var(--cream); font-weight: 600; }
    .confirm-actions {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      margin-top: 2rem;
    }
    .btn-selfserve {
      background: var(--pink);
      color: #fff;
      font-family: var(--font);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.9rem 2rem;
      border: none;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-selfserve:hover { background: #922E62; }
    .btn-home-link {
      background: none;
      border: none;
      color: var(--label);
      font-family: var(--font);
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      cursor: pointer;
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .btn-home-link:hover { color: var(--cream); }

    /* ── Footer ───────────────────────────────────────────── */
    footer {
      background: var(--green-deep);
      border-top: 1px solid var(--divider);
      padding: 2rem var(--side);
      text-align: center;
    }
    footer p {
      font-size: 0.75rem;
      color: var(--label);
      letter-spacing: 0.04em;
    }
    footer .amp { color: var(--pink); }
  </style>
</head>
<body>

  <!-- ── Navigation ─────────────────────────────────────── -->
  <nav>
    <div class="nav-inner">
      <div class="nav-logo" onclick="goHome()">
        Insurance <span class="amp">&</span> Shoebox
      </div>
      <ul class="nav-links">
        <li><button onclick="goHome()" id="nav-home" class="active">Home <span class="amp">&</span> Auto</button></li>
        <li><button onclick="showPage('advice'); setNav('advice')" id="nav-advice">Advice</button></li>
        <li><button class="login-btn" onclick="openSelfServe()">Login</button></li>
      </ul>
    </div>
  </nav>


  <!-- ══════════════════════════════════════════════════════ -->
  <!-- PAGE: Landing                                         -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="page active" id="page-landing">

    <!-- Hero -->
    <div class="hero-block">
      <p class="eyebrow">Home &amp; Auto Insurance</p>
      <h1>Your best rate.<br>In minutes.</h1>
      <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Get covered today with a plan that fits your life.</p>
      <button class="btn-primary" onclick="startQuote()">Get My Price →</button>
    </div>

    <!-- Trust bar -->
    <div class="trust-bar">
      <p>🔒 Secure &nbsp;·&nbsp; ⚡ Instant coverage &nbsp;·&nbsp; 🍁 Canadian-owned &nbsp;·&nbsp; ★★★★★ 4.8 rating</p>
    </div>

    <!-- Features -->
    <div class="content-section">
      <p class="section-title">Why Insurance Shoebox</p>
      <h2>Simple. Fast. Honest.</h2>
      <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
      <div class="feature-grid">
        <div class="feature-card">
          <div class="icon">⚡</div>
          <h3>Instant quotes</h3>
          <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit ut labore.</p>
        </div>
        <div class="feature-card">
          <div class="icon">🔒</div>
          <h3>Bank-level security</h3>
          <p>Ut enim ad minim veniam, quis nostrud exercitation ullamco.</p>
        </div>
        <div class="feature-card">
          <div class="icon">📱</div>
          <h3>Self-serve anytime</h3>
          <p>Duis aute irure dolor in reprehenderit in voluptate velit esse.</p>
        </div>
        <div class="feature-card">
          <div class="icon">🍁</div>
          <h3>Made for Canadians</h3>
          <p>Excepteur sint occaecat cupidatat non proident sunt in culpa.</p>
        </div>
      </div>
    </div>

    <!-- Second CTA -->
    <div style="text-align:center; padding: 2rem var(--side) 4rem;">
      <button class="btn-primary" onclick="startQuote()">Get My Price →</button>
    </div>

  </div><!-- /page-landing -->


  <!-- ══════════════════════════════════════════════════════ -->
  <!-- QUOTE FLOW WRAPPER                                    -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="page" id="page-quote">
    <div class="quote-wrap">

      <!-- Progress bar -->
      <div class="progress-bar">
        <div class="progress-steps">
          <div class="prog-step active" id="prog-1">
            <div class="prog-dot">1</div>
            <div class="prog-label">You</div>
          </div>
          <div class="prog-step" id="prog-2">
            <div class="prog-dot">2</div>
            <div class="prog-label">Details</div>
          </div>
          <div class="prog-step" id="prog-3">
            <div class="prog-dot">3</div>
            <div class="prog-label">Your quote</div>
          </div>
          <div class="prog-step" id="prog-4">
            <div class="prog-dot">4</div>
            <div class="prog-label">Payment</div>
          </div>
          <div class="prog-step" id="prog-5">
            <div class="prog-dot">✓</div>
            <div class="prog-label">Done</div>
          </div>
        </div>
      </div>


      <!-- ── STEP 1: About You ─────────────────────────── -->
      <div class="form-card" id="step-1">
        <h2>About you</h2>
        <p class="form-subtitle">Let's start with the basics. All information is kept secure.</p>

